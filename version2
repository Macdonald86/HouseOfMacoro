<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Motlokwa | Premium Limpopo Streetwear</title>
  <meta name="description" content="Motlokwa one-page premium e-store with pre-orders, WhatsApp ordering, payment options and admin controls." />
  <link rel="icon" href="assets/motlokwa-crest.png" />
  <style>
    :root {
      --ink: #11100d;
      --ink-soft: #26231d;
      --cream: #f7f1e7;
      --cream-2: #efe2cf;
      --paper: #fffaf1;
      --muted: #756a5f;
      --green: #173d31;
      --green-2: #0d2a22;
      --rust: #8a3f24;
      --gold: #c7a15a;
      --line: rgba(17, 16, 13, 0.12);
      --shadow: 0 24px 80px rgba(17, 16, 13, 0.18);
      --radius-lg: 32px;
      --radius-md: 20px;
      --radius-sm: 14px;
      --max: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      color: var(--ink);
      background:
        radial-gradient(circle at 12% 4%, rgba(199, 161, 90, 0.18), transparent 30%),
        radial-gradient(circle at 90% 9%, rgba(23, 61, 49, 0.14), transparent 34%),
        linear-gradient(180deg, var(--cream), #fff8ed 48%, #f3eadb);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.5;
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }
    button { cursor: pointer; }
    img, svg { display: block; max-width: 100%; }
    .hidden { display: none !important; }

    .notice-bar {
      width: 100%;
      background: var(--ink);
      color: var(--cream);
      font-size: .78rem;
      letter-spacing: .09em;
      text-transform: uppercase;
      display: flex;
      justify-content: center;
      gap: 2rem;
      padding: .72rem 1rem;
      flex-wrap: wrap;
    }

    .header {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(18px);
      background: rgba(247, 241, 231, .78);
      border-bottom: 1px solid var(--line);
    }

    .nav {
      max-width: var(--max);
      margin: 0 auto;
      min-height: 78px;
      padding: 0 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: .8rem;
      min-width: max-content;
    }

    .brand-mark {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(145deg, var(--ink), var(--green));
      color: var(--gold);
      display: grid;
      place-items: center;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.16), 0 12px 30px rgba(0,0,0,.16);
      position: relative;
      overflow: hidden;
    }

    .brand-mark::before {
      content: "";
      position: absolute;
      inset: 7px;
      border: 1px solid rgba(199, 161, 90, .7);
      border-radius: 50%;
    }

    .brand-mark strong {
      font-family: Georgia, serif;
      font-size: 1.45rem;
      line-height: 1;
      z-index: 1;
    }

    .brand-text strong { display: block; font-size: 1.08rem; letter-spacing: .08em; text-transform: uppercase; }
    .brand-text small { display: block; color: var(--muted); letter-spacing: .08em; font-size: .72rem; text-transform: uppercase; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: .35rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255, 250, 241, .72);
      padding: .3rem;
    }

    .nav-links a, .nav-links button {
      border: 0;
      background: transparent;
      border-radius: 999px;
      padding: .65rem .85rem;
      color: var(--ink-soft);
      font-weight: 700;
      font-size: .86rem;
    }

    .nav-links a:hover, .nav-links button:hover { background: var(--ink); color: var(--cream); }

    .nav-actions { display: flex; align-items: center; gap: .6rem; }
    .menu-btn { display: none; }

    .bag-btn, .btn {
      border: 0;
      border-radius: 999px;
      padding: .85rem 1.1rem;
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .55rem;
      transition: transform .2s ease, box-shadow .2s ease, background .2s ease;
      white-space: nowrap;
    }
    .bag-btn { background: var(--paper); border: 1px solid var(--line); color: var(--ink); }
    .bag-btn span {
      min-width: 24px; height: 24px; border-radius: 50%;
      background: var(--rust); color: white; display: inline-grid; place-items: center;
      font-size: .78rem;
    }
    .btn:hover, .bag-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(17,16,13,.13); }
    .btn.primary { background: var(--ink); color: var(--cream); }
    .btn.gold { background: var(--gold); color: var(--ink); }
    .btn.ghost { background: rgba(255, 250, 241, .72); border: 1px solid var(--line); color: var(--ink); }
    .btn.whatsapp { background: #128c7e; color: white; }
    .btn.small { padding: .58rem .78rem; font-size: .8rem; }
    .btn.danger { background: #7a1d1d; color: white; }
    .btn.full { width: 100%; }

    main { position: relative; }
    section { scroll-margin-top: 95px; }
    .container, .hero, .split-section, .shop, .preorder, .payments, .story, .newsletter, .footer-inner, .admin-panel {
      max-width: var(--max);
      margin: 0 auto;
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .hero {
      min-height: calc(100vh - 118px);
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, .95fr);
      gap: 2rem;
      align-items: center;
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .eyebrow {
      margin: 0 0 .75rem;
      color: var(--rust);
      font-weight: 900;
      letter-spacing: .14em;
      text-transform: uppercase;
      font-size: .78rem;
    }

    h1, h2, h3 { margin: 0; line-height: .96; letter-spacing: -.045em; }
    h1 {
      font-family: Georgia, "Times New Roman", serif;
      font-weight: 700;
      font-size: clamp(3.6rem, 9vw, 8rem);
      max-width: 760px;
    }
    h2 { font-family: Georgia, "Times New Roman", serif; font-size: clamp(2.2rem, 4.5vw, 4.8rem); }
    h3 { font-size: 1.08rem; letter-spacing: -.02em; line-height: 1.1; }
    .lead { color: var(--muted); font-size: clamp(1rem, 1.6vw, 1.25rem); max-width: 650px; margin: 1.3rem 0 0; }
    .hero-actions { display: flex; gap: .8rem; margin-top: 2rem; flex-wrap: wrap; }
    .proof-row {
      display: flex; flex-wrap: wrap; gap: .7rem;
      margin-top: 1.4rem;
    }
    .proof-row span {
      border: 1px solid var(--line);
      background: rgba(255, 250, 241, .68);
      border-radius: 999px;
      padding: .55rem .8rem;
      color: var(--muted);
      font-weight: 800;
      font-size: .84rem;
    }

    .hero-stage {
      position: relative;
      min-height: 610px;
      border-radius: 44px;
      background:
        linear-gradient(145deg, rgba(17,16,13,.92), rgba(23,61,49,.95)),
        radial-gradient(circle at 22% 18%, rgba(199,161,90,.3), transparent 33%);
      overflow: hidden;
      box-shadow: var(--shadow);
      padding: 1.4rem;
      color: var(--cream);
    }
    .hero-stage::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, transparent 48%, rgba(255,255,255,.06) 49%, transparent 50%),
        repeating-linear-gradient(0deg, rgba(255,255,255,.045) 0 1px, transparent 1px 34px);
      opacity: .52;
    }
    .drop-card {
      position: relative;
      z-index: 2;
      height: 100%;
      min-height: 575px;
      border: 1px solid rgba(255,255,255,.15);
      border-radius: 34px;
      padding: 1.3rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      background: rgba(255,255,255,.06);
      backdrop-filter: blur(18px);
    }
    .tag {
      width: max-content;
      border: 1px solid rgba(199,161,90,.7);
      border-radius: 999px;
      padding: .52rem .72rem;
      color: var(--gold);
      font-size: .75rem;
      font-weight: 900;
      letter-spacing: .1em;
      text-transform: uppercase;
    }
    .garment {
      position: relative;
      width: min(360px, 82%);
      aspect-ratio: 1 / 1.18;
      margin: 2rem auto;
      background: linear-gradient(160deg, #f5ede0, #c6b39a);
      clip-path: polygon(30% 4%, 70% 4%, 95% 25%, 82% 42%, 76% 33%, 76% 96%, 24% 96%, 24% 33%, 18% 42%, 5% 25%);
      box-shadow: inset 0 -30px 60px rgba(0,0,0,.15), 0 26px 70px rgba(0,0,0,.35);
    }
    .garment::before {
      content: "";
      position: absolute;
      top: 4%; left: 37%; right: 37%; height: 18%;
      border-radius: 0 0 50% 50%;
      border: 10px solid rgba(17,16,13,.22);
      border-top: 0;
    }
    .garment::after {
      content: "M";
      position: absolute;
      left: 50%; top: 34%; transform: translateX(-50%);
      width: 58px; height: 58px; border-radius: 50%;
      background: var(--green); color: var(--gold);
      display: grid; place-items: center;
      font-family: Georgia, serif; font-size: 1.55rem; font-weight: 800;
      box-shadow: 0 10px 22px rgba(0,0,0,.22), inset 0 0 0 1px rgba(199,161,90,.6);
    }
    .drop-info { display: grid; gap: .8rem; }
    .drop-info p { color: rgba(247,241,231,.74); margin: 0; }
    .drop-meta { display: grid; grid-template-columns: 1fr 1fr; gap: .7rem; }
    .drop-meta div { background: rgba(255,250,241,.09); border: 1px solid rgba(255,255,255,.13); border-radius: 18px; padding: .9rem; }
    .drop-meta span { display: block; font-size: .72rem; color: rgba(247,241,231,.65); text-transform: uppercase; letter-spacing: .08em; }
    .drop-meta strong { display: block; margin-top: .25rem; }

    .quick-order-card {
      position: relative;
      z-index: 3;
      margin-top: 1rem;
      border: 1px solid rgba(199,161,90,.38);
      border-radius: 28px;
      padding: 1rem;
      background: rgba(255,250,241,.10);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.08), 0 20px 50px rgba(0,0,0,.18);
      backdrop-filter: blur(16px);
    }
    .quick-order-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: .9rem;
    }
    .quick-order-head h2 { font-size: clamp(1.65rem, 3vw, 2.6rem); color: var(--cream); }
    .quick-pill {
      border: 1px solid rgba(199,161,90,.62);
      color: var(--gold);
      border-radius: 999px;
      padding: .45rem .65rem;
      font-size: .72rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .08em;
      white-space: nowrap;
      background: rgba(17,16,13,.25);
    }
    .quick-order-form { display: grid; gap: .75rem; }
    .quick-order-form label {
      color: rgba(247,241,231,.74);
      font-weight: 900;
      font-size: .82rem;
      display: grid;
      gap: .35rem;
    }
    .quick-order-form select, .quick-order-form input {
      width: 100%;
      border: 1px solid rgba(255,255,255,.16);
      background: rgba(255,250,241,.92);
      color: var(--ink);
      border-radius: 14px;
      padding: .78rem .82rem;
      outline: none;
    }
    .quick-row { display: grid; grid-template-columns: 1fr 110px; gap: .65rem; }
    .quick-summary { display: grid; grid-template-columns: repeat(2, 1fr); gap: .55rem; margin-top: .15rem; }
    .quick-summary div {
      border: 1px solid rgba(255,255,255,.13);
      background: rgba(255,250,241,.08);
      border-radius: 16px;
      padding: .72rem;
    }
    .quick-summary span {
      display: block;
      color: rgba(247,241,231,.58);
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      font-weight: 900;
    }
    .quick-summary strong { display: block; color: var(--cream); margin-top: .22rem; }
    .quick-note { margin: 0; color: rgba(247,241,231,.72); font-size: .86rem; }
    .quick-actions { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; }


    .trust {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 1.25rem 4rem;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: .8rem;
    }
    .trust article, .step-card, .pay-card, .product-card, .admin-card, .cart-card {
      border: 1px solid var(--line);
      background: rgba(255,250,241,.76);
      box-shadow: 0 14px 40px rgba(17,16,13,.07);
      border-radius: var(--radius-md);
    }
    .trust article { padding: 1.1rem; }
    .trust strong { display: block; font-size: .98rem; }
    .trust span { display: block; margin-top: .35rem; color: var(--muted); font-size: .9rem; }

    .preorder, .payments, .story, .shop, .newsletter { padding-top: 5rem; padding-bottom: 5rem; }
    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    .section-head p:not(.eyebrow) { color: var(--muted); max-width: 470px; margin: 0; }

    .steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: .9rem;
    }
    .step-card { padding: 1.1rem; min-height: 190px; display: flex; flex-direction: column; justify-content: space-between; }
    .step-card .num {
      color: var(--gold); font-family: Georgia, serif; font-size: 2.6rem; line-height: 1; font-weight: 800;
    }
    .step-card p { color: var(--muted); margin: .7rem 0 0; }

    .shop {
      background: linear-gradient(180deg, rgba(17,16,13,.04), rgba(17,16,13,0));
      max-width: none;
    }
    .shop-inner { max-width: var(--max); margin: 0 auto; padding: 0 1.25rem; }
    .filters { display: flex; gap: .6rem; flex-wrap: wrap; margin: 1.2rem 0 1.7rem; }
    .filter {
      border: 1px solid var(--line); background: rgba(255,250,241,.78); border-radius: 999px;
      padding: .7rem .95rem; font-weight: 800; color: var(--muted);
    }
    .filter.active { background: var(--ink); color: var(--cream); border-color: var(--ink); }
    .product-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    .product-card { overflow: hidden; }
    .product-visual {
      min-height: 290px;
      position: relative;
      padding: 1rem;
      background: linear-gradient(140deg, var(--green), var(--ink));
      display: flex; align-items: flex-end;
    }
    .product-visual .badge {
      position: absolute; top: 1rem; left: 1rem;
      background: rgba(255,250,241,.9); color: var(--ink); border-radius: 999px;
      padding: .42rem .7rem; font-size: .74rem; font-weight: 900; letter-spacing: .07em; text-transform: uppercase;
    }
    .product-visual .shape {
      width: 58%; max-width: 190px; aspect-ratio: 1 / 1.05; margin: 0 auto;
      background: rgba(255,250,241,.86);
      box-shadow: 0 24px 56px rgba(0,0,0,.28);
    }
    .shape.tee, .shape.hoodie { clip-path: polygon(30% 4%, 70% 4%, 96% 24%, 83% 43%, 76% 34%, 76% 96%, 24% 96%, 24% 34%, 17% 43%, 4% 24%); }
    .shape.cap { aspect-ratio: 1.7 / 1; border-radius: 60% 60% 24% 24%; clip-path: polygon(10% 42%, 25% 10%, 72% 10%, 94% 50%, 70% 72%, 8% 72%); }
    .shape.bag { border-radius: 12px 12px 28px 28px; clip-path: polygon(16% 24%, 84% 24%, 96% 96%, 4% 96%); }
    .product-body { padding: 1.1rem; }
    .product-top { display: flex; justify-content: space-between; gap: .8rem; align-items: start; }
    .price { font-weight: 900; font-size: 1.05rem; }
    .product-body p { color: var(--muted); min-height: 3.1em; margin: .7rem 0; }
    .product-controls { display: grid; grid-template-columns: 1fr 84px; gap: .6rem; margin: .9rem 0; }
    .product-controls select, .product-controls input, .checkout-form input, .checkout-form select, .checkout-form textarea, .admin-form input, .admin-form select, .admin-form textarea {
      width: 100%; border: 1px solid var(--line); background: rgba(255,250,241,.9); color: var(--ink);
      border-radius: 14px; padding: .78rem .82rem; outline: none;
    }
    .product-note { display: flex; justify-content: space-between; gap: .6rem; color: var(--muted); font-size: .82rem; border-top: 1px solid var(--line); padding-top: .75rem; }
    .product-note strong { color: var(--rust); }

    .payment-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .9rem; }
    .pay-card { padding: 1.1rem; }
    .pay-card span { display: block; color: var(--muted); margin-top: .35rem; }

    .story {
      display: grid;
      grid-template-columns: .9fr 1.1fr;
      align-items: center;
      gap: 2rem;
    }
    .story-art {
      min-height: 470px;
      border-radius: 42px;
      background:
        linear-gradient(145deg, rgba(23,61,49,.9), rgba(17,16,13,.95)),
        radial-gradient(circle at 70% 22%, rgba(199,161,90,.42), transparent 32%);
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.18);
    }
    .story-art::before {
      content: "";
      position: absolute;
      width: 80%; height: 38%; left: 10%; top: 34%;
      border: 12px solid rgba(247,241,231,.72);
      border-left: 0; border-right: 0;
      transform: skewY(-7deg);
    }
    .story-art::after {
      content: "MATOKS";
      position: absolute; bottom: 2rem; left: 2rem;
      color: rgba(199,161,90,.86); font-weight: 900; letter-spacing: .28em;
    }
    .story-content p:not(.eyebrow) { color: var(--muted); font-size: 1.05rem; }
    .story-tags { display: flex; flex-wrap: wrap; gap: .65rem; margin-top: 1.2rem; }
    .story-tags span { border: 1px solid var(--line); border-radius: 999px; padding: .6rem .8rem; background: rgba(255,250,241,.76); font-weight: 800; color: var(--ink-soft); }

    .newsletter {
      padding-bottom: 7rem;
    }
    .newsletter-card {
      border-radius: 42px;
      background: var(--ink);
      color: var(--cream);
      padding: clamp(1.5rem, 4vw, 3rem);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      align-items: center;
      box-shadow: var(--shadow);
      overflow: hidden;
      position: relative;
    }
    .newsletter-card::before {
      content: "";
      position: absolute; inset: 0;
      background: radial-gradient(circle at 82% 18%, rgba(199,161,90,.24), transparent 32%);
      pointer-events: none;
    }
    .newsletter-card > * { position: relative; z-index: 1; }
    .newsletter-card .eyebrow { color: var(--gold); }
    .newsletter-form { display: grid; gap: .75rem; }
    .newsletter-form input {
      width: 100%; border: 1px solid rgba(255,255,255,.17); background: rgba(255,255,255,.08); color: var(--cream);
      border-radius: 999px; padding: .95rem 1.1rem; outline: none;
    }
    .newsletter-form input::placeholder { color: rgba(247,241,231,.58); }
    .message { color: var(--green); font-weight: 800; margin: .5rem 0 0; }
    .newsletter .message { color: var(--gold); }

    .footer { border-top: 1px solid var(--line); background: rgba(255,250,241,.5); }
    .footer-inner {
      padding-top: 1.5rem; padding-bottom: 1.5rem;
      display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
      color: var(--muted); font-weight: 700;
    }

    .drawer, .modal-wrap {
      position: fixed;
      inset: 0;
      z-index: 100;
      pointer-events: none;
      opacity: 0;
      transition: opacity .2s ease;
    }
    .drawer.open, .modal-wrap.open { opacity: 1; pointer-events: auto; }
    .backdrop {
      position: absolute; inset: 0; background: rgba(17,16,13,.48); backdrop-filter: blur(7px);
    }
    .drawer-panel {
      position: absolute; top: 0; right: 0; height: 100%; width: min(460px, 100%);
      background: var(--paper); box-shadow: var(--shadow); padding: 1.1rem;
      display: flex; flex-direction: column;
      transform: translateX(100%);
      transition: transform .24s ease;
    }
    .drawer.open .drawer-panel { transform: translateX(0); }
    .drawer-head, .modal-head, .admin-head {
      display: flex; align-items: start; justify-content: space-between; gap: 1rem; border-bottom: 1px solid var(--line); padding-bottom: 1rem;
    }
    .close-btn {
      border: 1px solid var(--line); width: 42px; height: 42px; border-radius: 50%; background: var(--paper); font-size: 1.4rem; line-height: 1;
    }
    .cart-list { flex: 1; overflow-y: auto; padding: 1rem 0; display: grid; align-content: start; gap: .75rem; }
    .empty { color: var(--muted); text-align: center; padding: 3rem 1rem; }
    .cart-card { padding: .88rem; display: grid; grid-template-columns: 1fr auto; gap: .7rem; }
    .cart-card h4 { margin: 0 0 .25rem; }
    .cart-card p { margin: 0; color: var(--muted); font-size: .86rem; }
    .qty-row { display: flex; align-items: center; gap: .4rem; margin-top: .7rem; }
    .qty-row button { width: 30px; height: 30px; border-radius: 50%; border: 1px solid var(--line); background: var(--paper); font-weight: 900; }
    .remove-btn { border: 0; background: transparent; color: var(--rust); font-weight: 900; padding: 0; }
    .cart-footer { border-top: 1px solid var(--line); padding-top: 1rem; display: grid; gap: .75rem; }
    .totals { display: grid; gap: .45rem; }
    .totals div { display: flex; justify-content: space-between; color: var(--muted); }
    .totals strong { color: var(--ink); }
    .note { color: var(--muted); font-size: .86rem; margin: 0; }

    .modal-card {
      position: absolute; left: 50%; top: 50%; transform: translate(-50%, -48%);
      width: min(760px, calc(100% - 1.5rem)); max-height: calc(100vh - 2rem); overflow-y: auto;
