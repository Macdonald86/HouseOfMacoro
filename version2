              <label class="wide">Colour / gradient<input name="colour" value="linear-gradient(135deg, #173d31, #11100d)" /></label>
              <button class="btn primary wide" type="submit">Save product</button>
              <button class="btn ghost wide" type="button" id="clearProductForm">Clear form</button>
            </form>
          </div>

          <div class="admin-card">
            <h3>Products</h3>
            <div class="table-wrap"><table><thead><tr><th>Product</th><th>Price</th><th>Status</th><th>Actions</th></tr></thead><tbody id="productsTable"></tbody></table></div>
          </div>
        </div>

        <div class="admin-card" style="margin-top:1rem">
          <h3>Orders</h3>
          <div class="table-wrap"><table><thead><tr><th>Order</th><th>Customer</th><th>Items</th><th>Payment</th><th>Status</th><th>Actions</th></tr></thead><tbody id="ordersTable"></tbody></table></div>
        </div>
      </div>
    </div>
  </div>

  <a class="floating-whatsapp" id="floatingWhatsapp" href="#" target="_blank" rel="noopener">WhatsApp</a>

  <script>
    const CONFIG = {
      whatsappNumber: "27000000000",
      bankName: "Your Bank",
      accountName: "Motlokwa Apparel",
      accountNumber: "0000000000",
      branchCode: "000000"
    };

    const DEFAULT_PRODUCTS = [
      { id: "p1", title: "Bridge Crest Hoodie", category: "hoodies", price: 899, badge: "Pre-order", icon: "hoodie", preorder: true, depositPercent: 50, releaseDate: "Production closes 31 Aug", sizes: ["S", "M", "L", "XL", "XXL"], desc: "Heavyweight fleece hoodie with the official Motlokwa crest on the chest.", colour: "linear-gradient(135deg, #11100d, #173d31)" },
      { id: "p2", title: "Matoks Classic Tee", category: "tees", price: 349, badge: "Core", icon: "tee", preorder: false, depositPercent: 0, releaseDate: "Ready stock", sizes: ["S", "M", "L", "XL"], desc: "Premium cotton tee with clean heritage typography.", colour: "linear-gradient(135deg, #f2e4d0, #8a3f24)" },
      { id: "p3", title: "Tropic Capsule Tee", category: "tees", price: 399, badge: "Pre-order", icon: "tee", preorder: true, depositPercent: 40, releaseDate: "Dispatch 4–6 weeks", sizes: ["S", "M", "L", "XL", "XXL"], desc: "Minimal Tropic of Capricorn inspired graphic on a relaxed fit tee.", colour: "linear-gradient(135deg, #173d31, #c7a15a)" },
      { id: "p4", title: "Motlokwa Heritage Cap", category: "caps", price: 299, badge: "Limited", icon: "cap", preorder: true, depositPercent: 50, releaseDate: "Limited run", sizes: ["One size"], desc: "Structured cap with premium embroidered Motlokwa mark.", colour: "linear-gradient(135deg, #11100d, #8a3f24)" },
      { id: "p5", title: "Aana Motlokwana Tote", category: "accessories", price: 249, badge: "Accessory", icon: "bag", preorder: false, depositPercent: 0, releaseDate: "Ready stock", sizes: ["One size"], desc: "Canvas tote for daily carry, markets and weekend errands.", colour: "linear-gradient(135deg, #efe2cf, #173d31)" },
      { id: "p6", title: "Premium Crest Sweater", category: "hoodies", price: 749, badge: "Pre-order", icon: "hoodie", preorder: true, depositPercent: 50, releaseDate: "Production closes 15 Sep", sizes: ["S", "M", "L", "XL"], desc: "Classic crewneck sweater with refined official crest placement.", colour: "linear-gradient(135deg, #173d31, #11100d 72%, #c7a15a)" }
    ];

    const STORE_KEYS = {
      products: "motlokwa_onepage_products_v1",
      orders: "motlokwa_onepage_orders_v1",
      leads: "motlokwa_onepage_leads_v1"
    };

    let products = load(STORE_KEYS.products, DEFAULT_PRODUCTS);
    let orders = load(STORE_KEYS.orders, []);
    let cart = [];
    let currentFilter = "all";
    let editingProductId = null;
    let adminUnlocked = false;

    const money = n => `R${Number(n || 0).toLocaleString("en-ZA", { maximumFractionDigits: 0 })}`;
    const byId = id => document.getElementById(id);

    function load(key, fallback) {
      try { return JSON.parse(localStorage.getItem(key)) || structuredClone(fallback); }
      catch { return structuredClone(fallback); }
    }
    function save(key, value) { localStorage.setItem(key, JSON.stringify(value)); }
    function cartTotal() { return cart.reduce((sum, item) => sum + item.price * item.qty, 0); }
    function cartDueDeposit() { return cart.reduce((sum, item) => sum + dueForItem(item, "deposit"), 0); }
    function dueForItem(item, timing = "deposit") {
      if (timing === "full" || !item.preorder) return item.price * item.qty;
      return Math.ceil(item.price * item.qty * ((item.depositPercent || 0) / 100));
    }
    function orderDue(items, timing) { return items.reduce((sum, item) => sum + dueForItem(item, timing), 0); }
    function makeWhatsappUrl(message) { return `https://wa.me/${CONFIG.whatsappNumber}?text=${encodeURIComponent(message)}`; }

    function populateQuickOrder() {
      const productSelect = byId("quickProduct");
      if (!productSelect) return;
      const current = productSelect.value;
      productSelect.innerHTML = products.map(product => `<option value="${product.id}">${product.title} — ${money(product.price)}${product.preorder ? " • pre-order" : ""}</option>`).join("");
      if (products.some(product => product.id === current)) productSelect.value = current;
      renderQuickOrderDetails();
    }

    function selectedQuickProduct() {
      const selectedId = byId("quickProduct")?.value || products[0]?.id;
      return products.find(product => product.id === selectedId) || products[0];
    }

    function renderQuickOrderDetails() {
      const product = selectedQuickProduct();
      if (!product) return;
      const sizeSelect = byId("quickSize");
      const previousSize = sizeSelect?.value;
      if (sizeSelect) {
        sizeSelect.innerHTML = (product.sizes || ["One size"]).map(size => `<option value="${size}">${size}</option>`).join("");
        if ((product.sizes || []).includes(previousSize)) sizeSelect.value = previousSize;
      }
      const qty = Math.max(1, Number(byId("quickQty")?.value || 1));
      const timing = byId("quickPayment")?.value || "deposit";
      const total = product.price * qty;
      const due = timing === "full" || !product.preorder ? total : Math.ceil(total * ((product.depositPercent || 0) / 100));
      const balance = Math.max(0, total - due);
      byId("quickBadge").textContent = product.preorder ? `${product.depositPercent}% deposit` : "Ready stock";
      byId("quickPrice").textContent = money(product.price);
      byId("quickTotal").textContent = money(total);
      byId("quickDue").textContent = money(due);
      byId("quickBalance").textContent = money(balance);
      byId("quickNote").textContent = product.preorder
        ? `${product.releaseDate || "Pre-order item"}. Pay ${product.depositPercent}% now and settle the balance before delivery.`
        : "Ready-stock item. Full payment is due today.";
    }

    function addQuickOrderToCart({ checkout = false } = {}) {
      const product = selectedQuickProduct();
      if (!product) return;
      const size = byId("quickSize")?.value || (product.sizes || ["One size"])[0];
      const qty = Math.max(1, Number(byId("quickQty")?.value || 1));
      const existing = cart.find(item => item.id === product.id && item.size === size);
      if (existing) existing.qty += qty;
      else cart.push({ ...product, size, qty });
      updateCart();
      const timing = byId("quickPayment")?.value || "deposit";
      if (byId("paymentTiming")) byId("paymentTiming").value = timing;
      if (checkout) openCheckout();
      else openCart();
    }

    function quickOrderWhatsapp() {
      const product = selectedQuickProduct();
      if (!product) return;
      const size = byId("quickSize")?.value || (product.sizes || ["One size"])[0];
      const qty = Math.max(1, Number(byId("quickQty")?.value || 1));
      const timing = byId("quickPayment")?.value || "deposit";
      const total = product.price * qty;
      const due = timing === "full" || !product.preorder ? total : Math.ceil(total * ((product.depositPercent || 0) / 100));
      const balance = Math.max(0, total - due);
      const msg = `Hello Motlokwa, I would like to order from the landing page.

Product: ${product.title}
Size: ${size}
Qty: ${qty}
Order total: ${money(total)}
Payment choice: ${timing}
Due today: ${money(due)}
Balance later: ${money(balance)}`;
      window.open(makeWhatsappUrl(msg), "_blank");
    }

    function renderProducts() {
      const grid = byId("productGrid");
      const filtered = products.filter(p => currentFilter === "all" || (currentFilter === "preorder" ? p.preorder : p.category === currentFilter));
      grid.innerHTML = filtered.map(product => `
        <article class="product-card">
          <div class="product-visual" style="background:${product.colour}">
            <span class="badge">${product.badge}</span>
            <div class="shape ${product.icon || "tee"}" aria-hidden="true"></div>
          </div>
          <div class="product-body">
            <div class="product-top">
              <div><h3>${product.title}</h3><p>${product.desc}</p></div>
              <span class="price">${money(product.price)}</span>
            </div>
            <div class="product-controls">
              <select id="size-${product.id}" aria-label="Select size for ${product.title}">
                ${(product.sizes || ["One size"]).map(size => `<option value="${size}">${size}</option>`).join("")}
              </select>
              <input id="qty-${product.id}" type="number" min="1" value="1" aria-label="Quantity for ${product.title}" />
            </div>
            <button class="btn primary full" type="button" onclick="addToCart('${product.id}')">Add to bag</button>
            <div class="product-note"><span>${product.releaseDate || "Ready stock"}</span><strong>${product.preorder ? `${product.depositPercent}% deposit` : "Full payment"}</strong></div>
          </div>
        </article>
      `).join("") || `<p class="empty">No products in this category yet.</p>`;
    }

    function addToCart(productId) {
      const product = products.find(p => p.id === productId);
      if (!product) return;
      const size = byId(`size-${productId}`).value;
      const qty = Math.max(1, Number(byId(`qty-${productId}`).value || 1));
      const existing = cart.find(item => item.id === productId && item.size === size);
      if (existing) existing.qty += qty;
      else cart.push({ ...product, size, qty });
      updateCart();
      openCart();
    }
    window.addToCart = addToCart;

    function updateCart() {
      byId("cartCount").textContent = cart.reduce((sum, item) => sum + item.qty, 0);
      byId("cartTotal").textContent = money(cartTotal());
      byId("cartDue").textContent = money(cartDueDeposit());
      renderCartItems();
      renderCheckoutSummary();
    }

    function renderCartItems() {
      const el = byId("cartItems");
      if (!cart.length) {
        el.innerHTML = `<p class="empty">Your bag is empty. Add a Motlokwa item to start a pre-order.</p>`;
        return;
      }
      el.innerHTML = cart.map((item, index) => `
        <div class="cart-card">
          <div>
            <h4>${item.title}</h4>
            <p>Size: ${item.size} • ${item.preorder ? `${item.depositPercent}% deposit available` : "Ready stock"}</p>
            <div class="qty-row">
              <button type="button" onclick="changeQty(${index}, -1)">−</button>
              <strong>${item.qty}</strong>
              <button type="button" onclick="changeQty(${index}, 1)">+</button>
              <button class="remove-btn" type="button" onclick="removeCartItem(${index})">Remove</button>
            </div>
          </div>
          <strong>${money(item.price * item.qty)}</strong>
        </div>
      `).join("");
    }
    function changeQty(index, delta) {
      cart[index].qty += delta;
      if (cart[index].qty <= 0) cart.splice(index, 1);
      updateCart();
    }
    function removeCartItem(index) { cart.splice(index, 1); updateCart(); }
    window.changeQty = changeQty;
    window.removeCartItem = removeCartItem;

    function openCart() { byId("cartDrawer").classList.add("open"); byId("cartDrawer").setAttribute("aria-hidden", "false"); }
    function closeCart() { byId("cartDrawer").classList.remove("open"); byId("cartDrawer").setAttribute("aria-hidden", "true"); }
    function openCheckout() {
      if (!cart.length) { openCart(); return; }
      closeCart();
      byId("checkoutModal").classList.add("open");
      byId("checkoutModal").setAttribute("aria-hidden", "false");
      renderCheckoutSummary();
    }
    function closeCheckout() { byId("checkoutModal").classList.remove("open"); byId("checkoutModal").setAttribute("aria-hidden", "true"); }
    function openAdmin() { byId("adminModal").classList.add("open"); byId("adminModal").setAttribute("aria-hidden", "false"); renderAdmin(); }
    function closeAdmin() { byId("adminModal").classList.remove("open"); byId("adminModal").setAttribute("aria-hidden", "true"); }

    function renderCheckoutSummary() {
      const timing = byId("paymentTiming")?.value || "deposit";
      const total = cartTotal();
      const due = orderDue(cart, timing);
      const balance = Math.max(0, total - due);
      const summary = byId("checkoutSummary");
      if (!summary) return;
      summary.innerHTML = `
        <div><span>Items</span><strong>${cart.reduce((sum, item) => sum + item.qty, 0)}</strong></div>
        <div><span>Order total</span><strong>${money(total)}</strong></div>
        <div><span>Due today</span><strong>${money(due)}</strong></div>
        <div><span>Balance after deposit</span><strong>${money(balance)}</strong></div>
        <div><span>EFT details</span><strong>${CONFIG.bankName} • ${CONFIG.accountNumber}</strong></div>
      `;
    }

    function cartMessage(prefix = "Hello Motlokwa, I would like to place this order:") {
      const lines = cart.map(item => `- ${item.title} | Size: ${item.size} | Qty: ${item.qty} | ${money(item.price * item.qty)}${item.preorder ? ` | Deposit ${item.depositPercent}%` : ""}`);
      return `${prefix}\n\n${lines.join("\n")}\n\nTotal: ${money(cartTotal())}\nDeposit due today: ${money(cartDueDeposit())}`;
    }

    function submitOrder(event) {
      event.preventDefault();
      if (!cart.length) return;
      const form = new FormData(event.target);
      const paymentTiming = form.get("paymentTiming");
      const paymentMethod = form.get("paymentMethod");
      const order = {
        id: `MTL-${new Date().toISOString().slice(0,10).replaceAll("-", "")}-${Math.random().toString(36).slice(2, 6).toUpperCase()}`,
        date: new Date().toISOString(),
        customer: {
          name: form.get("name"), phone: form.get("phone"), email: form.get("email"), city: form.get("city"), address: form.get("address")
        },
        items: cart.map(item => ({ id: item.id, title: item.title, size: item.size, qty: item.qty, price: item.price, preorder: item.preorder, depositPercent: item.depositPercent })),
        total: cartTotal(),
        dueToday: orderDue(cart, paymentTiming),
        paymentTiming,
        paymentMethod,
        status: paymentMethod === "whatsapp" ? "WhatsApp confirmation" : "Pending payment"
      };
      orders.unshift(order);
      save(STORE_KEYS.orders, orders);
      byId("checkoutMessage").textContent = `Order ${order.id} created. Due today: ${money(order.dueToday)}.`;
      if (paymentMethod === "whatsapp") {
        const msg = `${cartMessage(`Hello Motlokwa, I have placed order ${order.id}.`)}\n\nName: ${order.customer.name}\nPhone: ${order.customer.phone}\nCity: ${order.customer.city}\nPayment: ${paymentTiming} via ${paymentMethod}\nDue today: ${money(order.dueToday)}`;
        window.open(makeWhatsappUrl(msg), "_blank");
      }
      cart = [];
      updateCart();
      renderAdmin();
      event.target.reset();
      renderCheckoutSummary();
    }

    function renderAdmin() {
      if (!adminUnlocked) return;
      byId("statProducts").textContent = products.length;
      byId("statOrders").textContent = orders.length;
      byId("statPreorders").textContent = orders.filter(o => o.items?.some(i => i.preorder)).length;
      byId("statDue").textContent = money(orders.reduce((sum, o) => sum + Number(o.dueToday || 0), 0));

      byId("productsTable").innerHTML = products.map(product => `
        <tr>
          <td><strong>${product.title}</strong><br><span class="note">${product.category} • ${product.sizes.join(", ")}</span></td>
          <td>${money(product.price)}</td>
          <td><span class="status-pill">${product.preorder ? `Pre-order ${product.depositPercent}%` : "Ready stock"}</span><br><span class="note">${product.releaseDate || ""}</span></td>
          <td><div class="table-actions"><button class="btn ghost small" type="button" onclick="editProduct('${product.id}')">Edit</button><button class="btn danger small" type="button" onclick="deleteProduct('${product.id}')">Delete</button></div></td>
        </tr>
      `).join("") || `<tr><td colspan="4">No products yet.</td></tr>`;

      byId("ordersTable").innerHTML = orders.map(order => `
        <tr>
          <td><strong>${order.id}</strong><br><span class="note">${new Date(order.date).toLocaleString()}</span></td>
          <td><strong>${order.customer?.name || ""}</strong><br><span class="note">${order.customer?.phone || ""}<br>${order.customer?.city || ""}</span></td>
          <td>${(order.items || []).map(item => `${item.title} (${item.size}) × ${item.qty}`).join("<br>")}</td>
          <td>Total: <strong>${money(order.total)}</strong><br>Due: <strong>${money(order.dueToday)}</strong><br><span class="note">${order.paymentTiming} • ${order.paymentMethod}</span></td>
          <td><select onchange="updateOrderStatus('${order.id}', this.value)">${["Pending payment", "WhatsApp confirmation", "Paid", "In production", "Ready for delivery", "Delivered", "Cancelled"].map(status => `<option ${order.status === status ? "selected" : ""}>${status}</option>`).join("")}</select></td>
          <td><div class="table-actions"><button class="btn ghost small" type="button" onclick="messageCustomer('${order.id}')">WhatsApp</button><button class="btn danger small" type="button" onclick="deleteOrder('${order.id}')">Delete</button></div></td>
        </tr>
      `).join("") || `<tr><td colspan="6">No orders yet. Test checkout to create one.</td></tr>`;
    }

    function editProduct(id) {
      const product = products.find(p => p.id === id);
      if (!product) return;
      editingProductId = id;
      const form = byId("productForm");
      const fields = form.elements;
      fields.id.value = product.id;
      fields.title.value = product.title;
      fields.category.value = product.category;
      fields.price.value = product.price;
      fields.badge.value = product.badge;
      fields.icon.value = product.icon;
      fields.sizes.value = product.sizes.join(", ");
      fields.preorder.value = String(product.preorder);
      fields.depositPercent.value = product.depositPercent;
      fields.releaseDate.value = product.releaseDate;
      fields.desc.value = product.desc;
      fields.colour.value = product.colour;
      byId("productFormTitle").textContent = "Edit product";
    }
    function deleteProduct(id) {
      products = products.filter(p => p.id !== id);
      save(STORE_KEYS.products, products);
      renderProducts();
      populateQuickOrder();
      renderAdmin();
    }
    function saveProduct(event) {
      event.preventDefault();
      const form = event.target;
      const fields = form.elements;
      const product = {
        id: fields.id.value || `p${Date.now()}`,
        title: fields.title.value.trim(),
        category: fields.category.value,
        price: Number(fields.price.value),
        badge: fields.badge.value.trim(),
        icon: fields.icon.value,
        sizes: fields.sizes.value.split(",").map(s => s.trim()).filter(Boolean),
        preorder: fields.preorder.value === "true",
        depositPercent: Number(fields.depositPercent.value || 0),
        releaseDate: fields.releaseDate.value.trim(),
        desc: fields.desc.value.trim(),
        colour: fields.colour.value.trim() || "linear-gradient(135deg, #173d31, #11100d)"
      };
      const existingIndex = products.findIndex(p => p.id === product.id);
      if (existingIndex >= 0) products[existingIndex] = product;
      else products.unshift(product);
      save(STORE_KEYS.products, products);
      clearProductForm();
      renderProducts();
      populateQuickOrder();
      renderAdmin();
    }
    function clearProductForm() {
      editingProductId = null;
      byId("productForm").reset();
      byId("productFormTitle").textContent = "Add product";
    }
    function updateOrderStatus(id, status) {
      const order = orders.find(o => o.id === id);
      if (order) { order.status = status; save(STORE_KEYS.orders, orders); renderAdmin(); }
    }
    function deleteOrder(id) {
      orders = orders.filter(o => o.id !== id);
      save(STORE_KEYS.orders, orders);
      renderAdmin();
    }
    function messageCustomer(id) {
      const order = orders.find(o => o.id === id);
      if (!order) return;
      const msg = `Hello ${order.customer.name}, this is Motlokwa regarding order ${order.id}. Your order status is: ${order.status}. Amount due today: ${money(order.dueToday)}.`;
      const phone = String(order.customer.phone || "").replace(/\D/g, "").replace(/^0/, "27");
      window.open(`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`, "_blank");
    }
    function exportCSV() {
      const rows = [["Order ID", "Date", "Name", "Phone", "City", "Items", "Total", "Due Today", "Payment", "Status"]];
      orders.forEach(order => rows.push([
        order.id, order.date, order.customer?.name, order.customer?.phone, order.customer?.city,
        (order.items || []).map(i => `${i.title} ${i.size} x${i.qty}`).join("; "),
        order.total, order.dueToday, `${order.paymentTiming} / ${order.paymentMethod}`, order.status
      ]));
      const csv = rows.map(row => row.map(value => `"${String(value ?? "").replaceAll('"', '""')}"`).join(",")).join("\n");
      const blob = new Blob([csv], { type: "text/csv" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `motlokwa-orders-${new Date().toISOString().slice(0,10)}.csv`;
      link.click();
      URL.revokeObjectURL(url);
    }
    function resetDemoData() {
      products = structuredClone(DEFAULT_PRODUCTS);
      orders = [];
      cart = [];
      save(STORE_KEYS.products, products);
      save(STORE_KEYS.orders, orders);
      clearProductForm();
      renderProducts(); populateQuickOrder(); updateCart(); renderAdmin();
    }
    window.editProduct = editProduct;
    window.deleteProduct = deleteProduct;
    window.updateOrderStatus = updateOrderStatus;
    window.deleteOrder = deleteOrder;
    window.messageCustomer = messageCustomer;

    document.addEventListener("DOMContentLoaded", () => {
      byId("year").textContent = new Date().getFullYear();
      renderProducts();
      populateQuickOrder();
      updateCart();
      byId("floatingWhatsapp").href = makeWhatsappUrl("Hello Motlokwa, I would like to enquire about the latest drop.");
      if (location.hash === "#admin") openAdmin();

      byId("menuBtn").addEventListener("click", () => byId("navLinks").classList.toggle("open"));
      document.querySelectorAll(".nav-links a").forEach(a => a.addEventListener("click", () => byId("navLinks").classList.remove("open")));
      byId("openCart").addEventListener("click", openCart);
      byId("checkoutBtn").addEventListener("click", openCheckout);
      byId("cartWhatsappBtn").addEventListener("click", () => window.open(makeWhatsappUrl(cartMessage()), "_blank"));
      byId("heroWhatsapp").addEventListener("click", quickOrderWhatsapp);
      byId("heroStartOrder").addEventListener("click", () => byId("quickOrderPanel").scrollIntoView({ behavior: "smooth", block: "center" }));
      byId("quickProduct").addEventListener("change", renderQuickOrderDetails);
      byId("quickSize").addEventListener("change", renderQuickOrderDetails);
      byId("quickQty").addEventListener("input", renderQuickOrderDetails);
      byId("quickPayment").addEventListener("change", renderQuickOrderDetails);
      byId("quickOrderForm").addEventListener("submit", event => { event.preventDefault(); addQuickOrderToCart({ checkout: true }); });
      byId("quickWhatsApp").addEventListener("click", quickOrderWhatsapp);
      byId("paymentTiming").addEventListener("change", renderCheckoutSummary);
      byId("checkoutForm").addEventListener("submit", submitOrder);
      byId("openAdminNav").addEventListener("click", openAdmin);
      byId("openAdminFooter").addEventListener("click", openAdmin);
      byId("productForm").addEventListener("submit", saveProduct);
      byId("clearProductForm").addEventListener("click", clearProductForm);
      byId("exportOrders").addEventListener("click", exportCSV);
      byId("resetDemo").addEventListener("click", resetDemoData);
      byId("logoutAdmin").addEventListener("click", () => { adminUnlocked = false; byId("adminPanel").classList.add("hidden"); byId("adminLogin").classList.remove("hidden"); });
      byId("loginForm").addEventListener("submit", event => {
        event.preventDefault();
        if (new FormData(event.target).get("password") === "motlokwa-admin") {
          adminUnlocked = true;
          byId("adminLogin").classList.add("hidden");
          byId("adminPanel").classList.remove("hidden");
          byId("loginMessage").textContent = "";
          renderAdmin();
        } else {
          byId("loginMessage").textContent = "Incorrect password.";
        }
      });
      byId("newsletterForm").addEventListener("submit", event => {
        event.preventDefault();
        const email = byId("newsletterEmail").value.trim();
        const leads = load(STORE_KEYS.leads, []);
        leads.push({ email, date: new Date().toISOString() });
        save(STORE_KEYS.leads, leads);
        byId("newsletterMessage").textContent = "You are on the Motlokwa drop list.";
        event.target.reset();
      });
      document.querySelectorAll("[data-close]").forEach(el => el.addEventListener("click", () => {
        const target = el.getAttribute("data-close");
        if (target === "cart") closeCart();
        if (target === "checkout") closeCheckout();
        if (target === "admin") closeAdmin();
      }));
      document.querySelectorAll(".filter").forEach(button => button.addEventListener("click", () => {
        document.querySelectorAll(".filter").forEach(b => b.classList.remove("active"));
        button.classList.add("active");
        currentFilter = button.dataset.filter;
        renderProducts();
      }));
    });
  </script>
</body>
</html>
